{
  "expo": {
    "name": "WaselGo Driver",
    "slug": "driver-app",
    "version": "1.1.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wasel-driver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#272865"
    },
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "qa.waselapp.driver",
      "config": {
        "googleMapsApiKey": "AIzaSyCcjyEPNrx4eRMYof-Z_4aEBjUdRQN8VlE"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby ride requests and navigate to passengers.",
        "NSLocationAlwaysUsageDescription": "We need your location to track your position during rides and receive nearby requests.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to track your position during rides and receive nearby requests.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "34",
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "qa.waselapp.driver",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCcjyEPNrx4eRMYof-Z_4aEBjUdRQN8VlE"
        }
      },
      "versionCode": 6,
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#272865",
          "image": "./assets/splash.png",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow WaselGo Driver to use your location to receive nearby ride requests and navigate to passengers.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WaselGo Driver needs access to your photo library so you can select photos of your driver documents for verification. For example, you can choose a photo of your driver's license from your library to upload for account approval.",
          "cameraPermission": "WaselGo Driver needs access to your camera so you can take photos of your driver documents for verification. For example, you can photograph your driver's license to upload for account approval."
        }
      ],
      "./plugins/iphone-only"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4747bf5d-9bb2-476d-9c9d-5a41358e1c4b"
      }
    },
    "owner": "rshafrah",
    "updates": {
      "url": "https://u.expo.dev/4747bf5d-9bb2-476d-9c9d-5a41358e1c4b"
    }
  }
}
