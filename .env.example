# Wasel — Single root env file
# Loaded by all 4 NestJS apps (admin-api, rider-api, driver-api, socket-api)
# via ConfigModule (envFilePath = monorepo-root/.env).
#
# Copy this file to `.env` and fill in real values. The `.env` file is gitignored.

# --- Database ---
DATABASE_URL="mysql://wasel:CHANGE_ME@localhost:3306/wasel"

# --- Auth ---
JWT_SECRET="CHANGE_ME"

# --- Runtime ---
NODE_ENV="production"

# --- Internal API (admin-api → rider-api refund call) ---
INTERNAL_API_KEY="CHANGE_ME"

# --- SkipCash Payment Gateway ---
# Use "sandbox" for testing, "production" for live
SKIPCASH_ENVIRONMENT="production"
SKIPCASH_CLIENT_ID="CHANGE_ME"
SKIPCASH_KEY_ID="CHANGE_ME"
SKIPCASH_SECRET_KEY="CHANGE_ME"
SKIPCASH_WEBHOOK_KEY="CHANGE_ME"
SKIPCASH_WEBHOOK_URL="https://api.waselapp.qa/rider-api/api/v1/skipcash/webhook"
SKIPCASH_RETURN_URL="https://api.waselapp.qa/rider-api/api/v1/skipcash/return"

# --- Twilio (SMS OTP for phone login) ---
TWILIO_ACCOUNT_SID="CHANGE_ME"
TWILIO_AUTH_TOKEN="CHANGE_ME"
TWILIO_VERIFY_SERVICE_SID="CHANGE_ME"

# --- Google Maps ---
GOOGLE_MAPS_API_KEY="CHANGE_ME"
